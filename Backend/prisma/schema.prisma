datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum Visibility {
  PRIVATE
  PUBLIC
}

enum FolderRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Provider{
  LOCAL
  GOOGLE
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?

  provider  Provider @default(LOCAL)
  googleId  String?  @unique
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  createdAt DateTime @default(now()) // default used so that e dont need to give the values
  updatedAt DateTime @updatedAt

  folders        Folder[]
  files          File[]

  sharedFolders FolderMember[]
  joinRequests  FolderJoinRequest[]
  activities    FolderActivity[]
}

model Folder {
  id        Int    @id @default(autoincrement())
  name      String

  pid       Int?
  parent    Folder?  @relation("FolderToFolder", fields: [pid], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderToFolder")

  uid       Int
  user      User @relation(fields: [uid], references: [id], onDelete: Cascade)

  files     File[]

  isShared       Boolean    @default(false)
  inviteCode     String?    @unique
  isInviteActive Boolean    @default(false)
  visibility     Visibility @default(PRIVATE)

  members    FolderMember[]
  requests   FolderJoinRequest[]
  activities FolderActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FolderMember {
  id Int @id @default(autoincrement())

  folderId Int
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  role FolderRole

  joinedAt DateTime @default(now())

  @@unique([folderId, userId])
}

model FolderJoinRequest {
  id Int @id @default(autoincrement())

  folderId Int
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  requestedBy Int
  user        User @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  message String?

  status RequestStatus @default(PENDING)

  requestedAt DateTime @default(now())

  @@unique([folderId, requestedBy])
}

model FolderActivity {
  id Int @id @default(autoincrement())

  folderId Int
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  action      String
  description String

  createdAt DateTime @default(now())
}

model File {
  id        Int      @id @default(autoincrement())
  orgName   String
  stoName   String   @unique
  mimeType  String
  size      Int

  folderId Int
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  uid  Int
  user User @relation(fields: [uid], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}