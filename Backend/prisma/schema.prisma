datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role{
    USER
    ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) // default used so that e dont need to give the values
  updatedAt DateTime @updatedAt

  folders   Folder[]
  files     File[]
}

model Folder{
  id        Int     @id @default(autoincrement())
  name      String

  pid       Int?
  parent    Folder?  @relation("FolderToFolder", fields: [pid], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderToFolder")

  uid       Int
  user      User    @relation(fields: [uid], references: [id], onDelete: Cascade)

  files     File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

model File {
  id        Int      @id @default(autoincrement())
  orgName   String
  stoName   String   @unique
  mimeType  String
  size      Int
  folderId  Int
  folder    Folder  @relation(fields: [folderId], references: [id], onDelete: Cascade)

  // Foreign relation for user
  uid       Int
  user      User    @relation(fields: [uid], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
