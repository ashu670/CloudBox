datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role{
    USER
    ADMIN
}

model User {
  id        Int     @id @default(autoincrement())
  name  String
  email     String  @unique
  password  String
  role      Role    @default(USER)
  createdAt DateTime @default(now()) // default used so that e dont need to give the values
  updatedAt DateTime @updatedAt
}
