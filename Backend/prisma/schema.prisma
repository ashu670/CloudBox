datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role{
    USER
    ADMIN
}

model User {
  id        Int     @id @default(autoincrement())
  username  String
  email     String  @unique
  password  String
  role      Role
  createdAt DateTime @default(now()) // default used so that e dont need to give the values
  updatedAt DateTime @updatedAt
}
